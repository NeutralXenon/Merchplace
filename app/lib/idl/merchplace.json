            ],
            "type": "i64"
          },
          {
            "name": "escrow_funded_at",
            "docs": [
              "Unix timestamp when escrow was funded (for timeout logic)."
            ],
            "type": "i64"
          },
          {
            "name": "listing_bump",
            "docs": [
              "Bump seed for the listing PDA."
            ],
            "type": "u8"
          },
          {
            "name": "escrow_bump",
            "docs": [
              "Bump seed for the escrow vault PDA."
            ],
            "type": "u8"
          },
          {
            "name": "usdc_mint",
            "docs": [
              "The USDC mint address this listing uses."
            ],
